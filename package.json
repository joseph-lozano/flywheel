    "sqids": "^0.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
